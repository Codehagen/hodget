{
  "name": "@workspace/engine",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./data": "./src/data/index.ts"
  },
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-fixtures": "node --experimental-strip-types fixtures/generate.ts",
    "demo": "vitest run -c vitest.demo.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9",
    "typescript": "^5",
    "vitest": "^3"
  }
}
